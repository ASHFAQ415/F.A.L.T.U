# ============================================================
#  Enterprise RAG Chatbot — Environment Configuration
#  Copy this file to .env and fill in your values
#  NEVER commit .env to Git — it contains secrets!
# ============================================================

# ─────────────────────────────────────────
# Security — CHANGE THESE BEFORE DEPLOYING
# ─────────────────────────────────────────

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CHANGE_ME_generate_a_random_256_bit_key_here

# First admin user (created on first startup)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME_strong_password_here
ADMIN_EMAIL=admin@example.com

# Grafana admin password
GRAFANA_PASSWORD=CHANGE_ME_grafana_password

# ─────────────────────────────────────────
# Ollama / LLM Settings
# ─────────────────────────────────────────

# LLM model for chat (runs locally via Ollama — FREE)
# Options: llama3.1:8b | llama3.2:3b | mistral:7b | phi3:mini | gemma2:2b
OLLAMA_MODEL=llama3.1:8b

# Embedding model (runs locally via Ollama — FREE)
OLLAMA_EMBED_MODEL=nomic-embed-text

# Ollama server URL (docker service name)
OLLAMA_BASE_URL=http://ollama:11434

# ─────────────────────────────────────────
# Data Storage
# ─────────────────────────────────────────

# Where to store ChromaDB, SQLite, and uploaded documents
DATA_DIR=/app/data

# ChromaDB collection prefix (one collection per corpus)
CHROMA_COLLECTION_PREFIX=rag

# ─────────────────────────────────────────
# RAG Settings
# ─────────────────────────────────────────

# Number of chunks retrieved before reranking
RETRIEVAL_TOP_K=20

# Number of chunks after reranking (sent to LLM as context)
RERANK_TOP_K=5

# Chunk size in tokens
CHUNK_SIZE=400

# Chunk overlap in tokens (for context continuity)
CHUNK_OVERLAP=60

# Semantic cache similarity threshold (0.0–1.0)
# Queries more similar than this threshold reuse cached answer
CACHE_SIMILARITY_THRESHOLD=0.92

# Cache TTL in seconds (1 hour)
CACHE_TTL_SECONDS=3600

# ─────────────────────────────────────────
# Auth / Session
# ─────────────────────────────────────────

# JWT token expiry in hours
JWT_EXPIRY_HOURS=24

# Algorithm for JWT signing
JWT_ALGORITHM=HS256

# ─────────────────────────────────────────
# Rate Limiting
# ─────────────────────────────────────────

# Max queries per user per minute
RATE_LIMIT_PER_MINUTE=20

# ─────────────────────────────────────────
# Logging
# ─────────────────────────────────────────

LOG_LEVEL=INFO

# ─────────────────────────────────────────
# Feature Flags
# ─────────────────────────────────────────

ENABLE_SEMANTIC_CACHE=true
ENABLE_OUTPUT_FILTERING=true
ENABLE_PII_REDACTION=true
ENABLE_RERANKING=true
